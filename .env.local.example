# ── GR Scale OS — Environment Variables ──
# Copy to .env.local for local dev; add the same keys in Vercel for production.
# Leave a key blank and that feature simply stays "off" — the app still runs.

# ── ACTIVE NOW ──────────────────────────────────────────────
# Supabase = your CRM database (leads, notes, pipeline persist here).
# Free project at https://supabase.com  → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── FUTURE AUTOMATION (leave blank for now — wired later, no code changes needed) ──
# Email sending (Gmail / Resend) — send outreach + proposals from the OS
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# RESEND_API_KEY=

# Google Calendar — auto-book strategy calls
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=

# Stripe — collect deposits, invoices, monthly maintenance
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# Google Maps — automated local lead discovery
# GOOGLE_MAPS_API_KEY=

# SMS / AI calling (Twilio / OpenPhone) — outreach + follow-up
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
